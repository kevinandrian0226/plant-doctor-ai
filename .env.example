# ============================================
# Plant Doctor AI - Environment Variables
# Salin file ini menjadi .env.local lalu isi nilainya
# ============================================

# --- Supabase ---
# Dapatkan dari: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (HANYA dipakai di server, JANGAN diekspos ke client)
# Dipakai untuk upload foto & operasi admin di API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic Claude (AI Vision) ---
# Dapatkan dari: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Model vision yang dipakai (opsional, default sudah di-set di kode)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- App ---
# Nama bucket Supabase Storage untuk foto tanaman
NEXT_PUBLIC_STORAGE_BUCKET=plant-photos
